    "start": "next start --hostname 0.0.0.0 -p 3000",
    "lint": "next lint",
    "prisma:migrate": "prisma migrate dev",
    "prisma:generate": "prisma generate",
    "prisma:seed": "prisma db seed",
    "backup": "ts-node scripts/backup.ts",
    "validate:samples": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" -r tsconfig-paths/register scripts/validateSamples.ts",
    "check:forced-zero": "ts-node --compiler-options \"{\\\"module\\\":\\\"CommonJS\\\"}\" -r tsconfig-paths/register scripts/checkForcedZero.ts"
  },
  "dependencies": {
    "@prisma/client": "5.9.0",
    "@sparticuz/chromium": "^143.0.4",
    "adm-zip": "^0.5.16",
