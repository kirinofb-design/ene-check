    "fs-extra": "^11.3.4",
    "graceful-fs": "^4.2.11",
    "jsonfile": "^6.2.1",
    "next": "14.2.35",
    "next-auth": "^5.0.0-beta.30",
    "node-cron": "^4.2.1",
    "playwright-core": "^1.59.1",
    "prisma": "5.9.0",
    "puppeteer": "^24.39.1",
    "puppeteer-extra": "^3.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2",
