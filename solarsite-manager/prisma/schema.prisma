generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String?
  password  String
  role      String   @default("user")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  uploadHistory UploadHistory[]
  alerts        Alert[]
  refreshTokens RefreshToken[]
  resetTokens   PasswordResetToken[]
  smaCookieCaches SmaCookieCache[]
  monitoringCredentials MonitoringCredential[]
}

model Site {
  id                       String           @id @default(cuid())
  siteName                 String
  laplaceCode              String?          // 例: "J-043"（ラプラス CSV の発電所コードと照合）
  location                 String?
  capacity                 Float
  monitoringSystem         String
  monitoringUrl            String
  startDate                DateTime?
  expectedAnnualGeneration Float?
  createdAt                DateTime         @default(now())
  updatedAt                DateTime         @updatedAt

  dailyGenerations DailyGeneration[]
  alerts           Alert[]
  uploadHistory    UploadHistory[]
  customFormats    CustomFormat[]
}

model DailyGeneration {
  id         String   @id @default(cuid())
  siteId     String
  date       DateTime
  generation Float
  status     String?
  notes      String?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  site Site @relation(fields: [siteId], references: [id])

  @@unique([siteId, date])
}

model UploadHistory {
  id          String   @id @default(cuid())
  userId      String
  siteId      String?
  fileName    String
  filePath    String
  fileSize    Int
  dataFormat  String
  recordCount Int
  successCount Int
  errorCount  Int
  uploadedAt  DateTime @default(now())

  user User  @relation(fields: [userId], references: [id])
  site Site? @relation(fields: [siteId], references: [id])
}

model Alert {
  id         String   @id @default(cuid())
  siteId     String
  alertType  String
  severity   String
  message    String
  detectedAt DateTime @default(now())
  resolvedAt DateTime?
  resolvedBy String?

  site  Site  @relation(fields: [siteId], references: [id])
  user  User? @relation(fields: [resolvedBy], references: [id])
}

model RefreshToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model PasswordResetToken {
  id        String   @id @default(cuid())
  token     String   @unique
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}

model LoginAttempt {
  id         String   @id @default(cuid())
  email      String
  ipAddress  String?
  success    Boolean
  attemptedAt DateTime @default(now())
}

model CustomFormat {
  id               String   @id @default(cuid())
  name             String
  monitoringSystem String
  siteId           String?
  isActive         Boolean  @default(true)
  // パース用のカスタム設定（例: dateKeys, generationKeys など）
  // SQLite では Json 型が使えないため JSON文字列として保持
  config           String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  site Site? @relation(fields: [siteId], references: [id])

  @@index([monitoringSystem, isActive])
  @@index([siteId, isActive])
}

model MonitoringCredential {
  id                String   @id @default(cuid())
  userId            String
  systemId          String   // eco-megane / fusion-solar / sunny-portal / grand-arch / solar-monitor-sf / solar-monitor-se
  loginId           String
  encryptedPassword String
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])

  @@unique([userId, systemId])
  @@index([systemId])
}

model SmaCookieCache {
  id         String   @id @default(cuid())
  userId     String   @unique
  cookieJson String   // JSON文字列（Playwright Cookie 配列）
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id])
}

