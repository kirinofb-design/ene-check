# PostgreSQL（本番・ローカル共通）。例: Neon の接続文字列 postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# 旧 SQLite（file:./dev.db）は廃止。ローカルも Neon の Dev 用 DB か、ローカル Postgres の URL を指定してください。
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# ログイン（NextAuth）: 32文字以上のランダム文字列。Vercel では必須（未設定で「Server configuration」エラー）。
NEXTAUTH_SECRET="generate-32-char-secret"
# v5 では AUTH_SECRET でも可（どちらか一方でよい）
# Auth.js v5 推奨の別名（任意）
# AUTH_SECRET="same-as-nextauth-secret"

# 本番 URL（Vercel）。例: https://ene-check.vercel.app （未設定だと認証コールバックが壊れることがある）
# NEXTAUTH_URL="https://ene-check.vercel.app"
# AUTH_URL="https://ene-check.vercel.app"

# 同じ LAN の別PCから http://(このPCのIP):3000 で開くとき
# NEXTAUTH_URL="http://192.168.0.10:3000"
UPLOAD_DIR="./uploads"
CREDENTIALS_ENCRYPTION_KEY="base64-32bytes-key"

# S3 を使う場合のみ設定
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Solar Monitor (Solar Frontier)
SOLAR_MONITOR_LOGIN_ID=""
SOLAR_MONITOR_PASSWORD=""

