# PostgreSQL（本番・ローカル共通）。例: Neon の接続文字列 postgresql://USER:PASSWORD@HOST/DB?sslmode=require
# 旧 SQLite（file:./dev.db）は廃止。ローカルも Neon の Dev 用 DB か、ローカル Postgres の URL を指定してください。
# アプリ起動時に connect_timeout 等が未指定なら自動付与するが、Neon では sslmode=require とプーラー用ホストの利用を推奨。
# 例（Neon プーラー）: postgresql://USER:PASSWORD@ep-xxx-pooler.ap-southeast-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?sslmode=require"
# ログイン（NextAuth）: 32文字以上のランダム文字列。Vercel では必須（未設定で「Server configuration」エラー）。
NEXTAUTH_SECRET="generate-32-char-secret"
# v5 では AUTH_SECRET でも可（どちらか一方でよい）
# Auth.js v5 推奨の別名（任意）
# AUTH_SECRET="same-as-nextauth-secret"

# 本番 URL（Vercel）。例: https://ene-check.vercel.app （未設定だと認証コールバックが壊れることがある）
# NEXTAUTH_URL="https://ene-check.vercel.app"
# AUTH_URL="https://ene-check.vercel.app"

# 同じ LAN の別PCから http://(このPCのIP):3000 で開くとき
# NEXTAUTH_URL="http://192.168.0.10:3000"
UPLOAD_DIR="./uploads"
CREDENTIALS_ENCRYPTION_KEY="base64-32bytes-key"

# Vercel 本番で「全データ一括取得」（/api/collect/all）を安定させるには推奨:
# 未設定だと 1 つのサーバ関数内で全コレクターを順実行し、ゲートウェイ 504 やメモリ枯渇のリスクが上がります。
# 設定すると各システムが /api/collect/system 経由の別インボケーションになり、maxDuration（300s）が「システムごと」に使えます。
# CRON_SECRET と同じ長いランダム文字列でよいです（サーバ間 Bearer 用）。
# COLLECT_FANOUT_SECRET="長いランダム文字列"
# ファンアウトを明示的に無効化するときのみ 0
# COLLECT_FANOUT_MODE="0"

# 任意: 「全データ一括取得」の実行方式（ブラウザに埋め込まれる NEXT_PUBLIC_*）。
# 未設定 … ホスト名が .vercel.app のときは「分割」（ゲートウェイ 504 回避）、localhost 等ではサーバ一括 POST /api/collect/all
# chunked … 常に分割（本番をカスタムドメインにしていても 504 を避けたいとき）
# server … 常にサーバ一括（自前ホストで maxDuration が長いとき）
# NEXT_PUBLIC_COLLECT_ALL_STRATEGY="chunked"

# 任意: 全データ一括取得のあと、指定期間の dailyGeneration をこの URL の DB にも複製する（Site は siteName で対応付け）。
# 例: ローカル開発の DATABASE_URL が Dev Neon、ここに本番 Neon の URL を入れると、ローカルで一括取得した日次データが本番 DB にも反映される。
# DATABASE_MIRROR_URL="postgresql://USER:PASSWORD@HOST/DB?sslmode=require"
AWS_S3_BUCKET=""
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# Solar Monitor (Solar Frontier)
SOLAR_MONITOR_LOGIN_ID=""
SOLAR_MONITOR_PASSWORD=""

# Vercel Cron（毎朝5:00 JST 実行）用
# Vercel 側にも同じ値を環境変数 CRON_SECRET として設定する
CRON_SECRET=""
# 自動収集を実行する対象ユーザー（どちらか片方を推奨）
CRON_COLLECT_USER_ID=""
CRON_COLLECT_USER_EMAIL=""

